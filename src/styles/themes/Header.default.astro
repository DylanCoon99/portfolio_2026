---
const navLinks = [
  { href: "/", label: "Home" },
  { href: "/projects", label: "Projects" },
  { href: "/blog", label: "Blog" },
  { href: "/about", label: "About" },
];

const currentPath = Astro.url.pathname;
---

<header class="border-b border-[var(--color-border)]">
  <nav class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="text-lg font-bold tracking-tight hover:text-[var(--color-accent)] transition-colors">
      Dylan
    </a>
    <ul class="flex gap-6 text-sm">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              "transition-colors hover:text-[var(--color-accent)]",
              currentPath === href || (href !== "/" && currentPath.startsWith(href))
                ? "text-[var(--color-accent)]"
                : "text-[var(--color-text-muted)]",
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
