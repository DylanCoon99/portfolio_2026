---
import TagList from "./TagList.astro";

interface Props {
  title: string;
  description: string;
  tags: string[];
  slug: string;
  image?: string;
}

const { title, description, tags, slug, image } = Astro.props;
---

<a
  href={`/projects/${slug}`}
  class="group block rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] overflow-hidden transition-all hover:border-[var(--color-accent)] hover:bg-[var(--color-surface-hover)]"
>
  {image && (
    <img
      src={image}
      alt={title}
      class="w-full h-48 object-cover border-b border-[var(--color-border)]"
    />
  )}
  <div class="p-5">
    <h3 class="font-semibold text-lg mb-2 group-hover:text-[var(--color-accent)] transition-colors">
      {title}
    </h3>
    <p class="text-sm text-[var(--color-text-muted)] mb-4 line-clamp-2">
      {description}
    </p>
    <TagList tags={tags} />
  </div>
</a>
